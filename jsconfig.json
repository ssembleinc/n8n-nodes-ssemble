{
	"compilerOptions": {
		"module": "commonjs",
		"moduleResolution": "node",
		"target": "es2019",
		"lib": ["es2019", "es2020", "es2022.error"],
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"checkJs": true,
		"allowJs": true,
		"baseUrl": ".",
		"paths": {
			"*": ["node_modules/*"]
		}
	},
	"include": [
		"credentials/**/*",
		"nodes/**/*",
		"*.js",
		"package.json"
	],
	"exclude": [
		"node_modules"
	],
	"typeAcquisition": {
		"enable": true,
		"include": ["node"]
	}
}
